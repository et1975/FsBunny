{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "windows": {
        "command": "build"
    },
    "linux": {
        "command": "./build.sh"
    },
    "osx": {
        "command": "./build.sh"
    },
    "tasks": [
        {
            "label": "doc",
            "type": "shell",
            "args": [
                "GenerateDocs"
            ],
            "problemMatcher": []
        },
        {
            "label": "build",
            "type": "shell",
            "args": [
                "Incremental"
            ],
            "problemMatcher": [],
            "group": {
                "_id": "build",
                "isDefault": false
            }
        },
        {
            "label": "watch",
            "type": "shell",
            "args": [
                "Watch"
            ],
            "isBackground": true,
            "problemMatcher": []
        }
    ]
}